# ============================================================
# Copilot Agent ROI Tracker — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# Server
PORT=3001
NODE_ENV=development

# Database (default: ./data/roi-tracker.db)
# DB_DIR=/path/to/data

# Microsoft Identity Platform (Entra ID)
# Register an app at https://portal.azure.com → App registrations
MS_TENANT_ID=your-tenant-id
MS_CLIENT_ID=your-client-id
MS_CLIENT_SECRET=your-client-secret

# Copilot Studio (optional — can also be configured per-environment in the UI)
# COPILOT_STUDIO_ENV_ID=your-environment-id

# Default Settings
DEFAULT_HOURLY_RATE=50
DEFAULT_CURRENCY=USD
DEFAULT_CURRENCY_SYMBOL=$
WORKING_HOURS_PER_DAY=8
WORKING_DAYS_PER_MONTH=22
ORGANIZATION_NAME=My Organization
